# ── ConstructAI Environment Variables ──

# Groq API Key (LLaMA response generation)
GROQ_API_KEY=

# Google Gemini API Key (Vision/OCR for engineering drawings)
GEMINI_API_KEY=

# Gemini model (free tier: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Gemini rate limit (requests per minute, keep under 15 for free tier)
GEMINI_RPM_LIMIT=8

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secure-jwt-secret-here

# Default Admin Password
ADMIN_PASSWORD=admin123

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# File storage
UPLOAD_DIR=./uploads
